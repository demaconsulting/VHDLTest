
    /// <summary>
    /// Test parsing options with empty string configuration file
    /// </summary>
    [TestMethod]
    public void Options_Parse_EmptyStringConfigFile_ThrowsException()
    {
        var arguments = Context.Create(["-c", ""]);
        var exception = Assert.ThrowsException<ArgumentException>(() => Options.Parse(arguments));
        Console.WriteLine($"Exception message: {exception.Message}");
    }
